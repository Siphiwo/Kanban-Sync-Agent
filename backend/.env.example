NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:pass@localhost:5432/kanbansync
JWT_SECRET=your-secret-key-change-this-in-production

# Asana OAuth Configuration
ASANA_CLIENT_ID=your-asana-client-id
ASANA_CLIENT_SECRET=your-asana-client-secret

# Trello OAuth Configuration  
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_SECRET=your-trello-api-secret

# Monday.com OAuth Configuration
MONDAY_CLIENT_ID=your-monday-client-id
MONDAY_CLIENT_SECRET=your-monday-client-secret

# ClickUp API Configuration (API Token based)
# Users will provide their own API tokens

# Jira OAuth Configuration
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret

WEBHOOK_SECRET=your-webhook-secret-change-this
FRONTEND_URL=http://localhost:3000